// Amazon FPGA Hardware Development Kit
//
// cl_id_defines.vh - SatSwarm CL PCIe identification defines
//
// CL_SH_ID0
// [31:16] - PCI Device ID
// [15:0]  - PCI Vendor ID
`define CL_SH_ID0       32'hF001_1D0F

// CL_SH_ID1
// [31:16] - PCI Subsystem ID
// [15:0]  - PCI Subsystem Vendor ID
`define CL_SH_ID1       32'h1D51_FEDD
